{
    "description": "IntelliJ IDEA: VimEverywhere (ctrl+shift+option+cmd+f to ctrl+cmd+backslash)",
    "manipulators": [
        {
            "type": "basic",
            "from": {
                "key_code": "f",
                "modifiers": {
                    "mandatory": [
                        "control",
                        "shift",
                        "option",
                        "command"
                    ]
                }
            },
            "to": [
                {
                    "key_code": "backslash",
                    "modifiers": [
                        "control",
                        "command"
                    ]
                }
            ],
            "conditions": [
                {
                    "type": "frontmost_application_if",
                    "bundle_identifiers": [
                        "^com\\.jetbrains\\.intellij$",
                        "^com\\.jetbrains\\.intellij\\.ce$"
                    ]
                }
            ]
        }
    ]
}
