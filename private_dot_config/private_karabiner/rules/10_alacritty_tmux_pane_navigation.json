{
    "description": "Alacritty: Sync tmux pane and aerospace window navigation",
    "manipulators": [
        {
            "type": "basic",
            "from": {
                "key_code": "h",
                "modifiers": {
                    "mandatory": [
                        "left_command",
                        "left_control",
                        "left_option",
                        "left_shift"
                    ]
                }
            },
            "to": [
                {
                    "key_code": "a",
                    "modifiers": [
                        "left_control"
                    ]
                },
                {
                    "key_code": "h",
                    "modifiers": [
                        "left_control"
                    ]
                }
            ],
            "conditions": [
                {
                    "type": "frontmost_application_if",
                    "bundle_identifiers": [
                        "^org\\.alacritty$"
                    ]
                }
            ]
        },
