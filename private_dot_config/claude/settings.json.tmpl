{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Skill",
      "Edit(~/ghq/**)",
      "Write(~/ghq/**)",
      "Bash(git *)",
      "Bash(gh *)"
    ]
  },
  "vim": true,
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": ["github.com", "api.github.com"]
    }
  },
  "experiments": {
    "lsp": true
  },
  "enabledPlugins": {
    "jdtls-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .configDir }}/claude/hooks/stop-hook.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .configDir }}/claude/hooks/notification-hook.sh"
          }
        ]
      }
    ]
  }
}
