{
  "experiments": {
    "lsp": true
  },
  "plugins": [
    {
      "id": "jdtls-lsp",
      "enabled": true
    },
    {
      "id": "code-review",
      "enabled": true
    },
    {
      "id": "pr-review-toolkit",
      "enabled": true
    }
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/stop-hook.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/notification-hook.sh"
          }
        ]
      }
    ]
  }
}
